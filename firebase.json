{
  "hosting": {
    "public": "dist",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "**/*.exe",
        "headers": [
          { "key": "Content-Type", "value": "application/octet-stream" },
          { "key": "Content-Disposition", "value": "attachment" }
        ]
      }
    ]
  }
}
